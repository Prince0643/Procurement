# Copy to /opt/procurement/.env.prod on VPS and update values.

# Database
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_USER=procurement_app
MYSQL_PASSWORD=change_me_app_password

# Backend
JWT_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=24h
NODE_ENV=production

# Frontend build-time API base
VITE_API_URL=https://procurement-api.xandree.com/api

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://procurement.xandree.com

# Optional attendance integration
ATTENDANCE_SYNC_API_KEY=
ATTENDANCE_API_URL=
ATTENDANCE_API_KEY=
